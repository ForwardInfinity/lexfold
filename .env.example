# copy thành .env — docker compose và make api đã tự set DATABASE_URL mặc định
DATABASE_URL=postgresql://lexfold:lexfold@localhost:5432/lexfold

# LLM gateway (D-41): extractor+composer MỘT họ model, judge KHÁC họ
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o
JUDGE_BASE_URL=https://api.anthropic.com/v1
JUDGE_API_KEY=
JUDGE_MODEL=claude-sonnet-4-5

# BGE-M3 local qua sentence-transformers (D-40)
EMBEDDING_MODEL=BAAI/bge-m3
