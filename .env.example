# copy thành .env — docker compose và make api đã tự set DATABASE_URL mặc định
DATABASE_URL=postgresql://lexfold:lexfold@localhost:5432/lexfold

# LLM gateway (D-41): extractor+composer MỘT họ model, judge KHÁC HỌ($LLM_MODEL ≠ họ $JUDGE_MODEL)
# OpenRouter (OpenAI-compatible) — một key phục vụ cả hai vai, miễn khác họ model
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=openai/gpt-4o
JUDGE_BASE_URL=https://openrouter.ai/api/v1
JUDGE_API_KEY=
JUDGE_MODEL=anthropic/claude-sonnet-4.5
# Gọi thẳng provider cũng được: LLM_BASE_URL=https://api.openai.com/v1, JUDGE_BASE_URL=https://api.anthropic.com/v1

# BGE-M3 local qua sentence-transformers (D-40)
EMBEDDING_MODEL=BAAI/bge-m3
